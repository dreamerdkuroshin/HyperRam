# ==============================================================================
# HyperRAM .gitignore
# Excludes: secrets, build artifacts, runtime files, logs, large binaries, OS junk
# ==============================================================================

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
secrets.yaml
config.local.*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnp/
.pnp.js
dist/
.cache/

# ── C / C++ Build Artifacts ───────────────────────────────────────────────────
*.obj
*.o
*.a
*.lib
*.dll
*.exp
*.ilk
*.pdb
*.ncb
*.sdf
*.suo
*.user
*.aps
*.pch
*.vspscc
*.vssscc
.vs/
x64/
x86/
Debug/
Release/
ipch/
*.aps

# ── Windows Driver Build Outputs ──────────────────────────────────────────────
*.sys
*.inf
# Uncomment below if you don't want to commit the compiled driver:
# HyperRAM.sys
# HyperRAM.inf

# ── Large Binary / Pool Files ─────────────────────────────────────────────────
hyperram.pool
hyperram-daemon/hyperram.pool
*.pool

# ── Runtime Log & Output Files ────────────────────────────────────────────────
*.log
*.txt
!README.md
!results/README.md
!hyperram-kernel-driver/install_success.txt

# Specific stdout/stderr dumps
ai_stderr.txt
ai_stdout.txt
client_stderr.txt
client_stdout.txt
sim_err2.txt
sim_out2.txt
sim_stderr.txt
sim_stdout.txt
daemon_*.txt
daemon_*.log

# ── Query / Temp Files ────────────────────────────────────────────────────────
query
queryex
test_pool_size.py

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Benchmark / Run Logs (runtime, not source) ───────────────────────────────
hyperram-daemon/complete_benchmark_run_*.log
hyperram-daemon/security_test_run.log
hyperram-daemon/validation_output.txt
hyperram-daemon/daemon_e2e_stderr.txt
hyperram-daemon/daemon_e2e_stdout.txt

# ── Kernel-driver install logs (runtime artifacts) ───────────────────────────
hyperram-kernel-driver/install_log.txt
hyperram-kernel-driver/hyperram-install-output.txt

# ── Build directory (compiled binaries) ──────────────────────────────────────
build/

# ── Results: keep CSVs, figures, README — but drop aggregate/temp ─────────────
results/figures/aggregate/

# Force-include important result data (overrides *.log / *.txt rules above)
!results/README.md
!results/**/*.csv
!results/figures/*.png
!results/stage1_repeat_run.log
!results/stage1_repeat_run_fixed.log
!results/stage1_run.log
!hyperram.pool.meta.json
